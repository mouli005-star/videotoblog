# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@db:5432/ytblog

# Redis
REDIS_URL=redis://redis:6379/0

# App secret (generate any random string)
SECRET_KEY=your-random-secret-key-here

# Google OAuth (same client_secrets from your existing project)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Groq (dev mode transcription + formatting)
GROQ_API_KEY=gsk_your-groq-key

# GPU server (production mode — leave empty for dev)
GPU_SERVER_URL=
GPU_SERVER_API_KEY=

# Pipeline mode: groq or gpu
TRANSCRIPTION_MODE=groq
FORMATTING_MODE=groq
